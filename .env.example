# ─────────────────────────────────────────────
#  Al Kawser LMS — Environment Variables
# ─────────────────────────────────────────────
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to source control.

# Supabase Project URL (Settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Supabase Anon/Public Key (Settings → API)
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Supabase Service Role Key (Settings → API)
# Required only for server-side admin tasks like creating admin users.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# YouTube Data API v3 Key (console.cloud.google.com)
VITE_YOUTUBE_API_KEY=YOUR_YOUTUBE_DATA_API_KEY

# App URL (used for certificate metadata)
VITE_APP_URL=http://localhost:3000
